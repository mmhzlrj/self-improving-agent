{
  "version": 1,
  "configLocation": "local",
  "chrome": {
    "startingDebugPort": 9222,
    "inactivityTimeoutMinutes": 5,
    "inactivityPollingMinutes": 2
  },
  "portMonitoring": {
    "portMonitoringFreqMs": {
      "block": 1000,
      "error": 2000,
      "inform": 5000
    }
  },
  "replay": {
    "maxConditionalDepth": 10,
    "maxRegexLength": 500,
    "showCursor": true,
    "playwrightExportPath": "./tests/e2e",
    "puppeteerExportPath": "./tests/puppeteer",
    "maxDelayMs": 1000
  },
  "changeDetection": {
    "enabled": true,
    "settleTimeout": 2000,
    "quietPeriod": 300,
    "navigationTimeout": 3000
  },
  "clickValidation": {
    "enabled": true,
    "validateNavigation": true,
    "requireDomChanges": false,
    "domChangesFailMode": "warn",
    "failOnConsoleErrors": true,
    "consoleErrorsFailMode": "error",
    "validateNetworkPayload": false,
    "networkFailMode": "warn",
    "postClickDelayMs": 100
  },
  "debug": {
    "enabled": false,
    "historyLogEnabled": false
  },
  "tools": {
    "enabled": [
      "issues",
      "connection",
      "tab",
      "breakpoint",
      "execution",
      "inspection",
      "source",
      "console",
      "network",
      "page",
      "dom",
      "screenshot",
      "input",
      "content",
      "modal",
      "storage",
      "download",
      "replay",
      "server",
      "dashboard"
    ],
    "disabled": []
  }
}